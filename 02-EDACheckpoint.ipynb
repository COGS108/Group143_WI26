        "adoption_rates = rq2.groupby(['city', 'breed_type'])['adopted'].mean().unstack()\n",
        "adoption_counts = rq2.groupby(['city', 'breed_type'])['adopted'].count().unstack()\n",
        "adoption_se = np.sqrt(adoption_rates * (1 - adoption_rates) / adoption_counts)\n",
        "\n",
        "city_order = ['Austin', 'Louisville', 'Sonoma', 'Bloomington']\n",
        "adoption_rates = adoption_rates.reindex(city_order)\n",
        "adoption_se = adoption_se.reindex(city_order)\n",
