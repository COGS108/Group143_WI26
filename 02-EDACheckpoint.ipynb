        "# chi-square test whcih checks whether two categorical variables (breed type and adoption outcome)\n",
        "# are independent. A small p-value (< 0.05) means the difference in adoption rates between\n",
        "# purebred and mixed-breed dogs is unlikely due to chance alone\n",
        "\n",
        "print(\"Chi-square tests of independence: breed_type vs. adoption outcome\\n\")\n",
        "print(\"=\" * 70)\n",
        "\n",
        "for city in city_order:\n",
        "    city_df = rq2[rq2['city'] == city]\n",
        "    ct = pd.crosstab(city_df['breed_type'], city_df['adopted'])\n",
        "    chi2, p, dof, expected = stats.chi2_contingency(ct)\n",
        "\n",
        "    ct_display = pd.crosstab(city_df['breed_type'], city_df['adopted'], margins=True)\n",
        "    ct_display.columns = ['Not Adopted', 'Adopted', 'Total']\n",
        "    ct_display.index = [idx if idx != 'All' else 'Total' for idx in ct_display.index]\n",
        "\n",
        "    print(f\"\\n--- {city} ---\")\n",
        "    display(ct_display)\n",
        "    print(f\"  Chi-square = {chi2:.2f},  df = {dof},  p = {p:.4e}\")\n",
        "    if p < 0.05:\n",
        "        print(f\"  → Statistically significant (p < 0.05)\")\n",
        "    else:\n",
        "        print(f\"  → Not statistically significant (p >= 0.05)\")\n",
        "    print()"
      ]
    },
